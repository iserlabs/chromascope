{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["build/**", "core/scope-bundle.js", "core/index.html"]
    },
    "build:lib": {
      "dependsOn": ["^build"],
      "outputs": ["build-lib/**"]
    },
    "@chromascope/processor#build": {
      "dependsOn": ["^build"],
      "outputs": ["target/debug/processor", "target/debug/processor.exe"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
